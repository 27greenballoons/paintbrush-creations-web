# Security headers for the static assets (Workers Static Assets supports _headers).
# Docs: https://developers.cloudflare.com/workers/static-assets/headers/
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains
  Cross-Origin-Opener-Policy: same-origin
  # Strict CSP: only the origins this page actually uses. Tailwind is compiled to
  # a static /styles.css and all scripts are external, so NO 'unsafe-inline' or
  # 'unsafe-eval' is needed. Turnstile is allowed for script/frame/connect; Google
  # Fonts for style/font. The contact form posts same-origin to the Worker.
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; style-src 'self' https://fonts.googleapis.com; script-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; connect-src 'self' https://challenges.cloudflare.com; form-action 'self'; upgrade-insecure-requests
